# development | production
DJANGO_ENVIRONMENT=development
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=

# sqlite for local development, postgresql for production
DJANGO_DB_ENGINE=sqlite
POSTGRES_DB=bewohnerformular
POSTGRES_USER=bewohnerformular
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Local development only. Production must use SMTP or Microsoft Graph integration.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@example.local

# Production hardening defaults are enabled automatically when DJANGO_DEBUG=False.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

PDF_COMPANY_NAME=Bewohner-Formularsystem
